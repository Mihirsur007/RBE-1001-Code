{"mode":"Text","hardwareTarget":"brain","textContent":"import math\nfrom vex import *\n\n# -----------------------------\n# BRAIN & CONTROLLER\n# -----------------------------\nbrain = Brain()\ncontroller = Controller()\n\n# -----------------------------\n# MOTORS (X-drive)\n# -----------------------------\nfront_left  = Motor(Ports.PORT1, GearSetting.RATIO_18_1, False)\nfront_right = Motor(Ports.PORT2, GearSetting.RATIO_18_1, True)\nback_left   = Motor(Ports.PORT3, GearSetting.RATIO_18_1, False)\nback_right  = Motor(Ports.PORT4, GearSetting.RATIO_18_1, True)\n\n# -----------------------------\n# INERTIAL SENSOR\n# -----------------------------\ninertial = Inertial(Ports.PORT5)\n\n# -----------------------------\n# STATES\n# -----------------------------\nSTANDBY     = 0\nMOVE        = 1\nCORRECTION  = 2\nCALIBRATION = 3\n\nstate = STANDBY\nprev_state = None\ntarget_heading = 0\n\n# -----------------------------\n# HELPER FUNCTIONS\n# -----------------------------\ndef stop_all():\n    front_left.stop()\n    front_right.stop()\n    back_left.stop()\n    back_right.stop()\n\ndef set_drive(fl, fr, bl, br):\n    front_left.spin(FORWARD, fl, PERCENT)\n    front_right.spin(FORWARD, fr, PERCENT)\n    back_left.spin(FORWARD, bl, PERCENT)\n    back_right.spin(FORWARD, br, PERCENT)\n\ndef field_oriented(x, y, heading):\n    rad = math.radians(heading)\n    temp = y * math.cos(rad) + x * math.sin(rad)\n    x = -y * math.sin(rad) + x * math.cos(rad)\n    y = temp\n    return x, y\n\ndef x_drive(x, y, rot):\n    fl = y + x + rot\n    fr = y - x - rot\n    bl = y - x + rot\n    br = y + x - rot\n    # Normalize\n    max_val = max(abs(fl), abs(fr), abs(bl), abs(br), 100)\n    return fl / max_val * 100, fr / max_val * 100, bl / max_val * 100, br / max_val * 100\n\ndef display_info():\n    # Clear the rest of the screen\n    brain.screen.set_fill_color(Color.BLACK)\n    brain.screen.draw_rectangle(10, 0, 470, 240)\n\n    # Draw colored state bar (10px wide on left)\n    color_map = {STANDBY: Color.GREEN, MOVE: Color.PURPLE, CORRECTION: Color.BLUE, CALIBRATION: Color.RED}\n    brain.screen.set_fill_color(color_map[state])\n    brain.screen.draw_rectangle(0, 0, 10, 240)  # 10px vertical bar\n    \n    # Print debug info\n    brain.screen.set_cursor(1,1)\n    brain.screen.set_font(FontType.MONOSPACE)\n    brain.screen.set_pen_color(Color.WHITE)\n    state_text = {STANDBY:\"STANDBY\", MOVE:\"MOVE\", CORRECTION:\"CORRECTION\", CALIBRATION:\"CALIBRATION\"}\n    brain.screen.print(f\"State: {state_text[state]}\")\n    brain.screen.new_line()\n    brain.screen.print(f\"Heading: {inertial.heading():.1f}\")\n    brain.screen.new_line()\n    brain.screen.print(f\"Target: {target_heading:.1f}\")\n    brain.screen.new_line()\n    brain.screen.print(\"Buttons:\")\n    brain.screen.new_line()\n    brain.screen.print(\"Up=MOVE  Down=COR  X=CAL\")\n    brain.screen.new_line()\n    brain.screen.print(\"L1/L2/R1/R2=STBY\")\n    brain.screen.new_line()\n    brain.screen.print(f\"Axis3(Y): {controller.axis3.position()}\")\n    brain.screen.new_line()\n    brain.screen.print(f\"Axis4(X): {controller.axis4.position()}\")\n    brain.screen.new_line()\n    brain.screen.print(f\"Axis1(Rot): {controller.axis1.position()}\")\n\n# -----------------------------\n# MAIN LOOP\n# -----------------------------\nwhile True:\n\n    # --- STATE TRANSITIONS ---\n    if controller.buttonX.pressing():\n        state = CALIBRATION\n    elif controller.buttonUp.pressing():\n        if state != MOVE:\n            target_heading = inertial.heading()\n        state = MOVE\n    elif controller.buttonDown.pressing():\n        if state != CORRECTION:\n            target_heading = inertial.heading()\n        state = CORRECTION\n    elif (controller.buttonL1.pressing() or controller.buttonL2.pressing() or\n          controller.buttonR1.pressing() or controller.buttonR2.pressing()):\n        state = STANDBY\n\n    # --- STATE LOGIC ---\n    if state == STANDBY:\n        stop_all()\n    elif state == CALIBRATION:\n        stop_all()\n        inertial.calibrate()\n        wait(2, SECONDS)\n        while inertial.is_calibrating():\n            wait(50, MSEC)\n        state = STANDBY\n    elif state == MOVE:\n        x = controller.axis4.position()\n        y = controller.axis3.position()\n        rot = controller.axis1.position()\n        x, y = field_oriented(x, y, inertial.heading())\n        fl, fr, bl, br = x_drive(x, y, rot)\n        set_drive(fl, fr, bl, br)\n    elif state == CORRECTION:\n        current = inertial.heading()\n        error = target_heading - current\n        if error > 180: error -= 360\n        elif error < -180: error += 360\n        correction = error * 0.5\n        x = controller.axis4.position()\n        y = controller.axis3.position()\n        rot = controller.axis1.position()\n        x, y = field_oriented(x, y, inertial.heading())\n        fl, fr, bl, br = x_drive(x, y, correction + rot)\n        set_drive(fl, fr, bl, br)\n\n    # --- DISPLAY ---\n    display_info()\n\n    wait(20, MSEC)","textLanguage":"python","robotConfig":[],"slot":2,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.64.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null}}